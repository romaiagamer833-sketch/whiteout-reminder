    <h2>Custom Reminders</h2>
    <input type="text" id="eventInput" placeholder="Enter event name (e.g., State Transfer)...">
    <input type="date" id="eventDate">
    <button onclick="addReminder()">Add Reminder</button>
    <ul id="remindersList" style="background: #f0fff0;"></ul>

    <script>
        function addReminder() {
            const input = document.getElementById('eventInput');
            const date = document.getElementById('eventDate');
            const list = document.getElementById('remindersList');
            if (input.value && date.value) {
                const li = document.createElement('li');
                li.textContent = `${input.value} on ${new Date(date.value).toLocaleDateString()}`;
                li.style.background = '#90ee90';
                li.style.margin = '10px 0';
                li.style.padding = '15px';
                li.style.borderRadius = '8px';
                list.appendChild(li);
                input.value = '';
                date.value = '';
            } else {
                alert('Please enter both event name and date.');
            }
        }
    </script>
</body>
